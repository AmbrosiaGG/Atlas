<!DOCTYPE html>
<html>
  <%- include('includes/head') %>

  <body class="transition-all antialiased bg-neutral-900">
    <header class="relative w-full overflow-hidden" style="height: 275px">
      <%- include('./includes/header.ejs') %>

      <div class="absolute left-0 top-0 -z-10 h-full w-full">
        <div
          class="headerGradient absolute left-0 top-0 z-[-1] h-full w-full"
          style="opacity: 0.75"
        ></div>
        <div
          class="absolute bottom-0 left-0 z-[-2] h-full w-full transition-all ease-in-out"
        >
          <div
            class="headerGradient scale-[1.3] blur-[25px] absolute bottom-0 left-0 my-auto h-full w-full transition-all ease-in-out bg-gradient-to-r from-[#7a49d0] to-[#7d5cb8]"
            style="color: transparent"
          ></div>
        </div>
      </div>

      <!-- Profile Section -->
      <div
        class="container mx-auto flex h-full flex-col justify-center gap-[14px] pb-[10px] lg:px-10"
      >
        <div style="opacity: 1">
          <div
            class="mt-2 flex w-full flex-col items-center justify-center gap-2 lg:flex-row lg:justify-start lg:gap-5"
          >
            <img
              alt="Profile Image"
              loading="lazy"
              width="1024"
              height="0"
              decoding="async"
              data-nimg="1"
              class="aspect-square w-[141px] rounded-full object-cover shadow-rankingAvater"
              src="<%= user.displayAvatarURL %>"
              style="color: transparent"
            />
            <div class="flex flex-col gap-2">
              <div class="text-center drop-shadow-sm lg:text-left">
                <h1 class="font-calsans text-white text-3xl">Hey <%= user.username %></h1>
                <h4 class="text-neutral-200">
                  You have admin access on these servers!
                </h4>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="grow bg-wavePage dark:bg-wavePage-darkMode mt-2">
      <div class="relative" style="opacity: 1; transform: none">
        <div class="z-30 pb-20 lg:pb-0 h-full">
          <div class="h-full w-full pb-10 pt-7">
            <div class="container lg:px-10 mx-auto -mt-4 box-border">
              <div class="flex flex-col gap-[3rem]">
                <div>
                  <h2 class="mb-4 mt-2 text-3xl font-calsans text-neutral-300">
                    Premium Servers
                  </h2>
                  <div
                    class="flex flex-col items-end overflow-hidden rounded-xl bg-panelBack text-darkText shadow-md dark:bg-panelBack-darkMode dark:text-darkText-darkMode dark:shadow-none md:hidden"
                  ></div>
                  <div
                    class="hidden w-full grid-cols-2 items-end gap-10 text-darkText dark:text-darkText-darkMode md:grid xl:grid-cols-3"
                  ></div>
                </div>
                <hr
                  class="mx-auto hidden w-4/5 md:block border border-neutral-700 bg-neutral-700"
                />
                <div>
                  <h2 class="mb-4 mt-2 text-3xl font-calsans text-neutral-300">
                    Regular Servers
                  </h2>
                  <div
                    class="flex flex-col items-end overflow-hidden rounded-xl bg-neutral-800 text-neutral-300 shadow-none md:hidden"
                  ></div>
                  <div
                    class="hidden w-full grid-cols-2 items-end gap-10 text-neutral-300 md:grid xl:grid-cols-3"
                  >
                    <% if(user.displayedGuilds){
                    user.displayedGuilds.forEach(function(guild) { %>
                    <div class="group relative shrink-0 grow">
                      <a
                        class="relative shrink-0 grow"
                        href="<%= guild.settingsUrl %>"
                        ><button
                          class="relative z-10 my-6 flex w-full flex-row items-center rounded-lg border border-neutral-700 bg-neutral-800 py-[11px] text-left transition ease-in-out active:bg-button-state-pressed group-focus-within:translate-x-2 group-hover:translate-x-1 group-active:translate-x-2"
                        >
                          <div
                            class="absolute -left-1 top-0 mx-4 flex aspect-square h-[100%] shrink-0 scale-150 overflow-hidden rounded-md border border-neutral-700 bg-neutral-800 drop-shadow-md transition-all ease-in-out"
                          >
                            <img
                              alt="NyaIchiNiSanNya"
                              loading="lazy"
                              width="1024"
                              height="0"
                              decoding="async"
                              data-nimg="1"
                              class="h-full w-full object-cover"
                              src="<%= guild.iconURL %>"
                              style="color: transparent"
                            />
                          </div>
                          <div
                            class="ml-4 flex shrink grow flex-col overflow-hidden break-words pl-28 tiny:ml-0"
                          >
                            <span
                              class="-mb-1 line-clamp-1 font-sans font-semibold text-[20px]"
                              ><%= guild.name %></span
                            >
                            <h4 class="truncate text-neutral-400"><% if (guild.settingsUrl.includes("https://discordapp.com")) { %> Not Invited <% } else { %> Invited <% } %></h4>
                          </div>
                          <div class="min-w-[30px] shrink-0"></div>
                          <svg
                            aria-hidden="true"
                            focusable="false"
                            data-prefix="fas"
                            data-icon="angle-right"
                            class="svg-inline--fa fa-angle-right absolute size-5 right-4 text-button-arrow"
                            role="img"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 320 512"
                          >
                            <path
                              fill="currentColor"
                              d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"
                            ></path>
                          </svg></button
                      ></a>
                    </div>
                    <% }); } else { %>
                          <h3 class="text-3xl text-white font-calsans">
                            <%= translate("dashboard:NO_SERVER") %>
                          </h3>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
