                            class="font-medium text-neutral-200 group-hover:opacity-75 opacity-50 relative font-inter text-tiny transition ease-in-out flex flex-row items-center justify-center gap-2 whitespace-nowrap p-[12px]"
                            href="/servers/914159389299073055/settings"
                            >Settings</a
                          >
                        </div>
                      </div>
                      <div class="flex items-center">
                        <div
                          class="mx-[12px] h-4 w-[1px] bg-darkText opacity-25 dark:bg-darkText-darkMode"
