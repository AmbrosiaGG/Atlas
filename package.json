{
    "name": "atlantabot",
    "version": "4.12.0",
    "description": "A very complete Discord bot (more than 70 commands) that uses the Discordjs API!",
    "main": "atlanta.js",
    "scripts": {
        "start": "node .",
        "lint": "eslint . --ext .js",
        "testcfg": "node scripts/verify-config.js",
        "css": "tailwind -i ./assets/css/globals.css -o ./assets/css/tailwind.css --watch"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ambrosiagg/atlas.git"
    },
    "author": "Androz2091",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/ambrosiagg/atlas/issues"
    },
    "homepage": "https://github.com/Androz2091/AtlantaBot#readme",
    "dependencies": {
        "@discord-player/extractor": "^3.0.0",
        "@discordjs/opus": "^0.7.0",
        "@k3rn31p4nic/google-translate-api": "github:k3rn31p4nic/google-translate-api",
        "@sentry/node": "^7.0.0",
        "@sindresorhus/slugify": "^1.1.0",
        "amethyste-api": "github:Androz2091/amethyste-api",
        "ascii-table": "0.0.9",
        "bree": "^9.2.4",
        "btoa": "^1.2.1",
        "cal-sans": "^1.0.1",
        "canvacord": "^5.2.0",
        "canvas": "^2.11.2",
        "chalk": "^4.1.2",
        "colors-generator": "^0.3.4",
        "connect-mongo": "^5.1.0",
        "cron": "^2.1.0",
        "discord.js": "^14.16.3",
        "ejs": "^3.1.8",
        "express": "^4.18.0",
        "express-session": "^1.17.3",
        "figlet": "^1.5.2",
        "i18next": "^23.15.2",
        "i18next-node-fs-backend": "^2.1.3",
        "lyrics-finder": "^21.7.0",
        "markdown-table": "2.0.0",
        "mathjs": "^11.9.0",
        "md5": "^2.3.0",
        "moment": "^2.29.4",
        "mongoose": "^7.6.0",
        "ms": "^2.1.3",
        "node-cron": "^3.0.3",
        "preline": "^2.5.0",
        "rootless-ssh": "^1.1.5",
        "string-sanitizer": "latest",
        "tailwind": "^4.0.0",
        "tailwindcss": "^3.4.13"
    },
    "devDependencies": {
        "eslint": "^8.47.0"
    },
    "eslintConfig": {
        "env": {
            "commonjs": true,
            "es2020": true,
            "node": true
        },
        "extends": "eslint:recommended",
        "globals": {
            "Atomics": "readonly",
            "SharedArrayBuffer": "readonly"
        },
        "parserOptions": {
            "ecmaVersion": 2020
        },
        "rules": {
            "prefer-const": [
                "error"
            ],
            "indent": [
                "error",
                "tab",
                {
                    "SwitchCase": 1
                }
            ],
            "quotes": [
                "error",
                "double"
            ],
            "semi": [
                "error",
                "always"
            ],
            "linebreak-style": 0,
            "require-atomic-updates": 0
        }
    },
    "eslintIgnore": [
        "dashboard/public"
    ]
}
